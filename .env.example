APP_NAME=Camera Map Video Service
DEBUG=true

POSTGRES_DB=camera_map
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/camera_map

REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_VIDEOS=videos
MINIO_BUCKET_PREVIEWS=previews
MINIO_SECURE=false

JWT_SECRET_KEY=change_me_secret_key
JWT_REFRESH_SECRET_KEY=change_me_refresh_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7